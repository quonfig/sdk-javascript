{
  "name": "@quonfig/javascript",
  "version": "0.0.13",
  "description": "Feature Flags & Dynamic Configuration — Browser/Client SDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "author": "Quonfig",
  "license": "MIT",
  "scripts": {
    "prebuild": "node scripts/generate-version.mjs",
    "build": "rm -rf dist/ && tsc",
    "bundle": "esbuild --minify --target=esnext --bundle --outfile=dist/quonfig.bundle.js --global-name=window.quonfigNamespace dist/index.js && echo 'window.quonfig = window.quonfigNamespace.quonfig' >> dist/quonfig.bundle.js",
    "lint": "eslint --ext .ts,.tsx src/",
    "test": "npm run build && jest --verbose --detectOpenHandles dist/ test/",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/quonfig/sdk-javascript.git"
  },
  "homepage": "https://github.com/quonfig/sdk-javascript#readme",
  "bugs": {
    "url": "https://github.com/quonfig/sdk-javascript/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "feature-flags",
    "config",
    "quonfig"
  ],
  "dependencies": {
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/uuid": "^9.0.5",
    "esbuild": "^0.19.0",
    "jest": "^29.7.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.0"
  }
}
